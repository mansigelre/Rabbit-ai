# .gitignore for Sales Insight Automator

# Environment variables
.env
.env.local
.env.*.local

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.DS_Store
frontend/*.log

# Backend  
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/venv/
backend/.venv/
backend/uploads/*
!backend/uploads/.gitkeep
backend/.eggs/
backend/*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Logs
*.log
logs/

# Cache
.cache/
*.cache
file_cache
